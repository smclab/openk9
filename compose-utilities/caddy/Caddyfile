localhost, *.localhost, *.*.localhost {
    tls internal

    handle /api/datasource/* {
        reverse_proxy openk9-api-gateway:8080
    }

    handle /api/tenant-manager/* {
        reverse_proxy openk9-tenant-manager:8080
    }

    handle /api/searcher/* {
        reverse_proxy openk9-api-gateway:8080
    }

    handle /api/rag/* {
        reverse_proxy openk9-api-gateway:8080
    }

    handle /api/ingestion/* {
        reverse_proxy openk9-api-gateway:8080
    }

    @adminPaths {
        path /admin /admin/*
    }
    handle @adminPaths {
        reverse_proxy admin-ui:8080
    }

    @tenantPaths {
        path /tenant /tenant/*
    }
    handle @tenantPaths {
        reverse_proxy tenant-ui:8080
    }

    @chatPaths {
	path /chat /chat/*
    }
    handle @chatPaths {
        reverse_proxy talk-to:8080
    }

    handle {
        reverse_proxy search-frontend:8080
    }
}
