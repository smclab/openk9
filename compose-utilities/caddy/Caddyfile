localhost, *.localhost, *.*.localhost {
    tls internal

    handle /api/datasource/* {
        reverse_proxy openk9-datasource:8080
    }

    handle /api/tenant-manager/* {
        reverse_proxy openk9-tenant-manager:8080
    }

    handle /api/searcher/* {
        reverse_proxy openk9-searcher:8080
    }

    handle /api/ingestion/* {
        reverse_proxy openk9-ingestion:8080
    }

    handle /api/rag/* {
        reverse_proxy rag-module:5000
    }

    @adminPaths {
        path /admin /admin/*
    }
    handle @adminPaths {
        reverse_proxy openk9-admin-ui:8080
    }

    @tenantPaths {
        path /tenant /tenant/*
    }
    handle @tenantPaths {
        reverse_proxy openk9-tenant-ui:8080
    }

    @chatPaths {
        path /chat /chat/*
    }
    handle @chatPaths {
        reverse_proxy talk-to:8080
    }

    handle {
        reverse_proxy openk9-search-frontend:8080
    }
}
