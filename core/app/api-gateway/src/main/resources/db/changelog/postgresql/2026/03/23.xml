<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	logicalFilePath="2026/03/23.xml">

	<changeSet id="1774486800-1" author="openk9">
		<addColumn tableName="api_key">
			<column name="expiration_date" type="TIMESTAMPTZ"/>
		</addColumn>
	</changeSet>

	<!-- Delete legacy api_key rows that lack api_group/expiration_date.
	     Event replay will re-insert them with the correct values. -->
	<changeSet id="1774486800-2" author="openk9">
		<delete tableName="api_key"/>
		<addColumn tableName="api_key">
			<column name="api_group" type="VARCHAR(32)">
				<constraints nullable="false"/>
			</column>
		</addColumn>
	</changeSet>

</databaseChangeLog>
