<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	logicalFilePath="2026/03/10.xml">

	<!-- Null out DISABLED sentinel values in tenant OAuth2 columns -->
	<changeSet id="1773346800-1" author="openk9">
		<sql>
			UPDATE tenant
			SET issuer_uri = NULL
			WHERE issuer_uri = 'DISABLED';
		</sql>
		<sql>
			UPDATE tenant
			SET client_id = NULL
			WHERE client_id = 'DISABLED';
		</sql>
		<sql>
			UPDATE tenant
			SET client_secret = NULL
			WHERE client_secret = 'DISABLED';
		</sql>
	</changeSet>

</databaseChangeLog>
