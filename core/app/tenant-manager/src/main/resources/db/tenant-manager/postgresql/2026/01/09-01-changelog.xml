<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	logicalFilePath="db/tenant-manager/2026/01/09-changelog.xml">

	<changeSet id="1771514819-1" author="openk9">
		<createTable tableName="api_key">
			<column name="id" type="BIGINT">
				<constraints nullable="false"
							 primaryKey="true"
							 primaryKeyName="api_key_pkey"
				/>
			</column>
			<column name="tenant_id" type="BIGINT">
				<constraints nullable="false"
							 foreignKeyName="fk_api_key_tenant"
							 referencedTableName="tenant"
							 referencedColumnNames="id"/>
			</column>
			<column name="hash" type="VARCHAR(255)"/>
			<column name="name" type="VARCHAR(255)"/>
			<column name="api_group" type="VARCHAR(50)">
				<constraints nullable="false"/>
			</column>
			<column name="status" type="VARCHAR(50)">
				<constraints nullable="false"/>
			</column>
			<column name="prefix" type="VARCHAR(255)"/>
			<column name="suffix" type="VARCHAR(255)"/>
			<column name="create_date" type="TIMESTAMP WITH TIME ZONE"/>
			<column name="expiration_date" type="TIMESTAMP WITH TIME ZONE"/>
		</createTable>
	</changeSet>

</databaseChangeLog>
