<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	logicalFilePath="db/tenant-manager/2026/03/26-changelog.xml">

	<!-- Rename SecurityConfiguration enum values. -->
	<changeSet id="1774780800-1" author="openk9">

		<update tableName="tenant">
			<column name="security_configuration" value="OAUTH2_ADMIN_ONLY"/>
			<where>security_configuration = 'LEGACY'</where>
		</update>

		<update tableName="tenant">
			<column name="security_configuration" value="OAUTH2_SEARCH"/>
			<where>security_configuration = 'PROFILED_LEGACY'</where>
		</update>

		<update tableName="tenant">
			<column name="security_configuration" value="OAUTH2_SEARCH_WITH_API_KEY"/>
			<where>security_configuration = 'PROFILED'</where>
		</update>

		<update tableName="tenant">
			<column name="security_configuration" value="OAUTH2_ADMIN_WITH_API_KEY"/>
			<where>security_configuration = 'PUBLIC_USAGE'</where>
		</update>

		<update tableName="tenant">
			<column name="security_configuration" value="NO_GATEWAY_AUTH"/>
			<where>security_configuration = 'BASIC_AUTH'</where>
		</update>

	</changeSet>

	<changeSet id="1774780800-2" author="openk9">
		<addDefaultValue tableName="tenant"
			columnName="security_configuration"
			defaultValue="OAUTH2_ADMIN_ONLY"/>
	</changeSet>

</databaseChangeLog>
