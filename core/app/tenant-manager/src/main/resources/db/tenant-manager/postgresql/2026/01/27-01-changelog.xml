<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	logicalFilePath="db/tenant-manager/2026/01/27-changelog.xml">

	<changeSet id="1769505783-1" author="openk9">

		<addColumn tableName="tenant">
			<column name="security_configuration" type="VARCHAR(50)" defaultValue="LEGACY">
				<constraints nullable="false"/>
			</column>
		</addColumn>

	</changeSet>

	<changeSet id="1769505783-2" author="openk9">

		<addColumn tableName="tenant">
			<column name="issuer_uri" type="VARCHAR(255)" />
		</addColumn>

	</changeSet>

	<changeSet id="1769505783-3" author="openk9">
		<customChange class="io.openk9.tenantmanager.init.BackfillTenantIssuerUriTask"/>
	</changeSet>

	<changeSet id="1769505783-4" author="openk9">

		<dropColumn tableName="tenant">
			<column name="realm_name"/>
		</dropColumn>

	</changeSet>

</databaseChangeLog>
