<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	logicalFilePath="db/tenant-manager/2026/03/10-01-changelog.xml">

	<!-- 1. Make OAuth2 columns nullable first -->
	<changeSet id="1773346800-1" author="openk9">
		<dropNotNullConstraint
			tableName="tenant"
			columnName="client_id"
			columnDataType="VARCHAR(255)"/>
		<dropNotNullConstraint
			tableName="tenant"
			columnName="issuer_uri"
			columnDataType="VARCHAR(255)"/>
	</changeSet>

	<!-- 2. Null out DISABLED sentinel values -->
	<changeSet id="1773346800-2" author="openk9">
		<sql>
			UPDATE tenant
			SET issuer_uri = NULL
			WHERE issuer_uri = 'DISABLED';
		</sql>
		<sql>
			UPDATE tenant
			SET client_id = NULL
			WHERE client_id = 'DISABLED';
		</sql>
		<sql>
			UPDATE tenant
			SET client_secret = NULL
			WHERE client_secret = 'DISABLED';
		</sql>
	</changeSet>

	<!-- 3. Migrate API_KEY_ONLY to LEGACY -->
	<changeSet id="1773346800-3" author="openk9">
		<sql>
			UPDATE tenant
			SET security_configuration = 'LEGACY'
			WHERE security_configuration = 'API_KEY_ONLY';
		</sql>
	</changeSet>

</databaseChangeLog>
