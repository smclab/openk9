<databaseChangeLog
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS"
	logicalFilePath="db/datasource/2026/05/15-01-changelog.xml"
>

	<changeSet id="1778843787-0" author="openk9">
		<comment>
			api_url is now an optional external provider URL: drop the NOT NULL
			constraint before clearing the obsolete internal-target values.
		</comment>
		<dropNotNullConstraint tableName="embedding_model" columnName="api_url"/>
	</changeSet>

	<changeSet id="1778843787-1" author="openk9">
		<comment>
			Reset embedding_model.api_url: the column semantics changed from internal
			gRPC target to external provider URL. Existing values are no longer valid.
		</comment>
		<sql>
			UPDATE embedding_model SET api_url = NULL WHERE api_url IS NOT NULL
		</sql>
	</changeSet>

</databaseChangeLog>
