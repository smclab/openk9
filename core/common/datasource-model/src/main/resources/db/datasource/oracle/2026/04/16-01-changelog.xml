<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS"
	logicalFilePath="db/datasource/2026/04/16-01-changelog.xml">

	<changeSet id="1776328055-1" author="openk9">
		<comment>Remove orphaned query_parser_config rows with no search_config</comment>
		<delete tableName="query_parser_config">
			<where>search_config IS NULL</where>
		</delete>
	</changeSet>

	<changeSet id="1776328055-2" author="openk9">
		<comment>Remove duplicate query_parser_config rows keeping the one with the highest id per (search_config, type)</comment>
		<sql>
			DELETE FROM query_parser_config
			WHERE id NOT IN (
				SELECT MAX(id) FROM query_parser_config
				GROUP BY search_config, type
			)
		</sql>
	</changeSet>

	<changeSet id="1776328055-3" author="openk9">
		<comment>Add unique constraint on (search_config, type) to prevent duplicate query parser types per search config</comment>
		<addUniqueConstraint columnNames="search_config,type"
							constraintName="uk_query_parser_config_search_config_type"
							tableName="query_parser_config"/>
	</changeSet>

</databaseChangeLog>
