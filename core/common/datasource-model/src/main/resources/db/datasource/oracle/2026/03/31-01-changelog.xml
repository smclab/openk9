<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
	objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS"
	logicalFilePath="db/datasource/2026/03/31-01-changelog.xml">

	<changeSet id="1774966618-1" author="openk9">
		<preConditions onFail="MARK_RAN">
			<columnExists tableName="rag_configuration" columnName="range_start"/>
		</preConditions>
		<dropColumn tableName="rag_configuration" columnName="range_start"/>
	</changeSet>

	<changeSet id="1774966618-2" author="openk9">
		<preConditions onFail="MARK_RAN">
			<columnExists tableName="rag_configuration" columnName="range_end"/>
		</preConditions>
		<dropColumn tableName="rag_configuration" columnName="range_end"/>
	</changeSet>

	<changeSet id="1774966618-3" author="openk9">
		<addColumn tableName="rag_configuration">
			<column
				name="range_start"
				type="INTEGER" defaultValueNumeric="0"
			/>
		</addColumn>
	</changeSet>

	<changeSet id="1774966618-4" author="openk9">
		<addColumn tableName="rag_configuration">
			<column
				name="range_end"
				type="INTEGER" defaultValueNumeric="5"
			/>
		</addColumn>
	</changeSet>

</databaseChangeLog>
